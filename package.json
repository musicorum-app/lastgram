{
  "name": "@musicorum-app/lastgram",
  "version": "2.0.0-rc.1",
  "description": "lastgram made simple",
  "main": "dist/index.js",
  "type": "module",
  "author": "lyricalsoul <hello@lyricalsoul.io>",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "database:generate": "bunx prisma generate",
    "database:deploy": "bunx prisma migrate deploy",
    "database:migrate": "bunx prisma migrate dev",
    "i18n:sync": "bunx i18next-locales-sync -p en -s pt es -l path/to/locales/folder --spaces 2",
    "cli:updateDiscordCommands": "bun src/cli.ts updateDiscordCommands",
    "cli:checkTranslations": "bun src/cli.ts checkTranslations",
    "typecheck": "tsc --noEmit"
  },
  "nodemonConfig": {
    "ignore": [
      "src/**"
    ]
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/marked": "^6.0.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@musicorum/lastfm": "^0.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "country-emoji": "^2.0.1",
    "date-fns": "^4.4.0",
    "discord.js": "^14.26.4",
    "i18next": "^26.3.4",
    "i18next-fs-backend": "^2.6.6",
    "ioredis": "^5.11.1",
    "marked": "^18.0.5",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3"
  }
}
