datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

model User {
  id         Int      @id @default(autoincrement())
  platformId String   @unique
  language   String   @default("en")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  isBanned         Boolean @default(false)
  revealUser       Boolean @default(false)
  sendPhotosAsLink Boolean @default(false)
  sendTags         Boolean @default(false)
  private          Boolean @default(false)

  likedEmoji  String  @default("❤️")
  banNote     String?
  sessionKey  String?
  displayName String

  lastFmUsername String
  lastFmUser     LastFmUser @relation(fields: [lastFmUsername], references: [fmUsername], onDelete: Cascade)

  groupMemberships GroupMember[]
  crownHolders     CrownHolder[]
}

model LastFmUser {
  fmUsername  String   @id
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // the orange tree for the user
  users User[]

  entityScrobbles EntityScrobble[]
}

model Group {
  id        String   @id
  title     String?
  language  String   @default("en")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      GroupMember[]
  crowns       Crown[]
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

enum EntityType {
  ARTIST
  ALBUM
  TRACK
}

model Entity {
  id        Int        @id @default(autoincrement())
  mbid      String
  name      String
  type      EntityType
  coverUrl  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entityScrobbles EntityScrobble[]
  crowns          Crown[]

  @@unique([type, mbid])
  @@index([type])
  @@index([name])
}

model EntityScrobble {
  id         Int      @id @default(autoincrement())
  entityId   Int
  fmUsername String
  playCount  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lastFmUser LastFmUser @relation(fields: [fmUsername], references: [fmUsername], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([fmUsername, entityId])
  @@index([fmUsername])
  @@index([playCount(sort: Desc)])
}

model Crown {
  id            Int      @id @default(autoincrement())
  groupId       String
  entityId      Int
  claimed       Boolean  @default(false)
  switchedTimes Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group        Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entity       Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  crownHolders CrownHolder[]

  @@unique([groupId, entityId])
  @@index([entityId])
  @@index([groupId])
}

model CrownHolder {
  id              Int      @id @default(autoincrement())
  crownId         Int
  userId          Int
  playCount       Int
  isCurrentHolder Boolean  @default(false)
  createdAt       DateTime @default(now())

  crown    Crown   @relation(fields: [crownId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([crownId, userId])
  @@index([userId])
}
